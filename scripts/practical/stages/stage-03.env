# Stage 3 — Scale / Edge environment configuration.
# Sourced by scripts/practical/*.sh. Values here are defaults; override via
# real environment variables before invoking the driver scripts.

STAGE_ID="stage-03"
STAGE_DIR="stage-03-scale-edge"
STAGE_TITLE="Stage 3 — Scale / Edge"

# Resource group and region.
RG="${RG:-rg-practical-storefront-stage03}"
LOCATION="${LOCATION:-koreacentral}"

# Bicep template and parameters (relative to repo root).
TEMPLATE_FILE="infra/bicep/stages/stage-03-scale-edge/main.bicep"
PARAMETERS_FILE="infra/bicep/stages/stage-03-scale-edge/main.bicepparam"

# Deployment parameter values passed on the command line.
APP_BASE_NAME="${APP_BASE_NAME:-storefront}"
SQL_ADMIN_LOGIN="${SQL_ADMIN_LOGIN:-storefrontadmin}"
# SQL_ADMIN_PASSWORD must be exported by the caller; never commit a value here.
# SQL_ENTRA_ADMIN_LOGIN, SQL_ENTRA_ADMIN_OBJECT_ID, and ALERT_EMAIL_ADDRESS
# must also be exported by the caller before deploying this stage.

# Verification smoke tests to run for this stage.
VERIFY_SCRIPTS=("http-smoke.sh" "sql-smoke.sh" "identity-smoke.sh" "frontdoor-smoke.sh")
