@model IEnumerable<Practical.Storefront.Web.Models.Order>
@{
    ViewData["Title"] = "Recent Orders";
}
<h1>Recent Orders</h1>
<p><a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Back to catalog</a></p>
<table class="table">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Product</th>
            <th>Quantity</th>
            <th>Placed (UTC)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.CustomerName</td>
                <td>@(order.Product?.Name ?? "(unknown)")</td>
                <td>@order.Quantity</td>
                <td>@order.CreatedAt.ToString("u")</td>
            </tr>
        }
    </tbody>
</table>
