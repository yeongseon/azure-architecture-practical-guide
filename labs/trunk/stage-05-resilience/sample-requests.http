@frontDoorUrl = https://REPLACE-WITH-YOUR-ENDPOINT.z01.azurefd.net
@primaryWebAppUrl = https://REPLACE-WITH-YOUR-PRIMARY-WEBAPP.azurewebsites.net
@secondaryWebAppUrl = https://REPLACE-WITH-YOUR-SECONDARY-WEBAPP.azurewebsites.net

### Front Door home page (expect 200 after propagation, HTML)
GET {{frontDoorUrl}}/
Accept: text/html

### Front Door health check (expect 200, {"status":"Healthy"})
GET {{frontDoorUrl}}/healthz
Accept: application/json

### Front Door ops info (expect 200, JSON; region shows "primary" before failover)
GET {{frontDoorUrl}}/ops/info
Accept: application/json

### Primary origin ops info bypassing Front Door (expect 200, region "primary")
GET {{primaryWebAppUrl}}/ops/info
Accept: application/json

### Secondary origin ops info bypassing Front Door (expect 200, region "secondary")
GET {{secondaryWebAppUrl}}/ops/info
Accept: application/json

### Create an order through the edge (expect 302 redirect; write reaches the failover-group listener)
POST {{frontDoorUrl}}/Home/Create
Content-Type: application/x-www-form-urlencoded

ProductId=1&Quantity=2&CustomerName=Demo+User
